# Copy to .env and fill in. HELIUS_API_KEY alone is enough — the RPC URL is derived.
HELIUS_API_KEY=your-helius-api-key
# Optional overrides:
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key
# PORT=4180
# Throughput (paid Helius plan can go higher):
# REWARD_CONCURRENCY=8
# MAX_SIG_PAGES=10
# MAX_ENHANCED_TX=4000
